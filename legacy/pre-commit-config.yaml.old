repos:
  - repo: https://github.com/astral-sh/ruff-pre-commit
    rev: v0.12.11
    hooks:
#      - id: ruff
#        args: [--fix]
      - id: ruff-format

# Temporarily disabled - re-enable after architecture refactoring complete
#  - repo: local
#    hooks:
#      - id: ty
#        name: ty
#        entry: uv run ty
#        language: system
#        types: [python]
#        args: [check, src/erenshor, tests/]
#        pass_filenames: false

#  - repo: local
#    hooks:
#      - id: pytest-with-coverage
#        name: pytest-with-coverage
#        entry: uv run pytest
#        language: system
#        args: [tests/, -v, --tb=short, --cov=erenshor, --cov-fail-under=60, --cov-report=term-missing:skip-covered]
#        pass_filenames: false

  - repo: https://github.com/jorisroovers/gitlint
    rev: v0.19.1
    hooks:
      - id: gitlint
        stages: [commit-msg]
        args: [--contrib=contrib-title-conventional-commits, --ignore=body-is-missing, --staged, --msg-filename]