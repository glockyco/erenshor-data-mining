# ============================================================================
# Default Behavior
# Normalize line endings to LF on commit and checkout (modern best practice)
* text=auto eol=lf
# Shell Scripts - CRITICAL: Must use LF
# Unix shell scripts MUST have LF endings or they will fail to execute
*.sh text eol=lf
cli/bin/erenshor text eol=lf
