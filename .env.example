# Erenshor Configuration
# Copy this file to .env and fill in your values
# All settings are optional - defaults from config.toml will be used

# ==============================================================================
# VERSION 3.0 - UNIFIED CONFIGURATION
# ==============================================================================
#
# This .env file works alongside config.toml for the unified Erenshor project.
# Use .env for secrets and local overrides.
# Use config.toml (or config.local.toml) for project-wide settings.
#
# Configuration Precedence (highest to lowest):
# 1. Environment variables (ERENSHOR_* from this file or system)
# 2. .env file (this file - gitignored)
# 3. .erenshor/config.local.toml (gitignored local overrides)
# 4. config.toml (tracked project defaults)
#
# ==============================================================================
# BASH CLI CONFIGURATION
# ==============================================================================

# Steam credentials (for game download)
# ERENSHOR_STEAM_USERNAME=yourusername

# Repository root (auto-detected from Git, override if needed)
# REPO_ROOT=/path/to/Erenshor

# ==============================================================================
# PYTHON CONFIGURATION - PATHS
# ==============================================================================

# Path to database file (variant-specific or explicit path)
# Default: Resolved from PathResolver or config.toml variant settings
# ERENSHOR_DB_PATH=/path/to/erenshor-main.sqlite

# Directory for cached wiki pages (fetched from wiki)
# Default: wiki_cache (in project root)
# ERENSHOR_CACHE_DIR=wiki_cache

# Directory for generated/updated wiki pages (ready to upload)
# Default: wiki_updated (in project root)
# ERENSHOR_OUTPUT_DIR=wiki_updated

# Directory for operation reports (JSONL event logs, summaries)
# Default: out/reports
# ERENSHOR_REPORTS_DIR=out/reports

# ==============================================================================
# PYTHON CONFIGURATION - MEDIAWIKI API
# ==============================================================================

# MediaWiki API endpoint URL
# Default: https://erenshor.wiki.gg/api.php (from config.toml)
# ERENSHOR_API_URL=https://erenshor.wiki.gg/api.php

# Number of pages to fetch per API request (1-50)
# Default: 25 (from config.toml)
# ERENSHOR_API_BATCH_SIZE=25

# Delay in seconds between API fetch requests
# Default: 1.0 (from config.toml)
# ERENSHOR_API_DELAY=1.0

# Maximum pages to upload in one batch
# Default: 10 (from config.toml)
# ERENSHOR_UPLOAD_BATCH_SIZE=10

# Delay in seconds between uploads
# Default: 1.0 (from config.toml)
# ERENSHOR_UPLOAD_DELAY=1.0

# Default edit summary for uploads
# Default: "Automated wiki update" (from config.toml)
# ERENSHOR_UPLOAD_EDIT_SUMMARY=Automated wiki update

# Mark uploads as minor edits by default
# Default: true (from config.toml)
# ERENSHOR_UPLOAD_MINOR_EDIT=true

# ==============================================================================
# BOT CREDENTIALS (REQUIRED for uploads)
# ==============================================================================

# MediaWiki bot username (from Special:BotPasswords)
# REQUIRED for wiki push command (actual uploads)
# NEVER commit this file with real credentials!
# ERENSHOR_BOT_USERNAME=YourBotName@YourBotJob

# MediaWiki bot password (from Special:BotPasswords)
# REQUIRED for wiki push command (actual uploads)
# NEVER commit this file with real credentials!
# ERENSHOR_BOT_PASSWORD=your_bot_password_here

# ==============================================================================
# GOOGLE SHEETS CONFIGURATION
# ==============================================================================

# Path to Google Cloud service account credentials JSON file
# Default: $HOME/.config/erenshor/google-credentials.json (from config.toml)
# ERENSHOR_GOOGLE_SHEETS_CREDENTIALS_FILE=/path/to/google-credentials.json

# Or use service account JSON directly (alternative to credentials file)
# ERENSHOR_GOOGLE_SHEETS_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# Google Sheets batch size (rows per upload)
# Default: 1000 (from config.toml)
# ERENSHOR_GOOGLE_SHEETS_BATCH_SIZE=1000

# ==============================================================================
# VARIANT CONFIGURATION
# ==============================================================================

# Enable/disable variants (overrides config.toml)
# ERENSHOR_VARIANTS_PLAYTEST_ENABLED=true
# ERENSHOR_VARIANTS_DEMO_ENABLED=false

# Override variant-specific settings
# ERENSHOR_VARIANTS_MAIN_DATABASE=/custom/path/erenshor-main.sqlite
# ERENSHOR_VARIANTS_PLAYTEST_APP_ID=3090030

# ==============================================================================
# MOD DEVELOPMENT
# ==============================================================================

# Path to Erenshor game installation (for mod deployment and testing)
# Required for: uv run erenshor mod deploy, uv run erenshor mod launch
#
# Windows (Steam):
#   ERENSHOR_GAME_PATH=C:/Program Files (x86)/Steam/steamapps/common/Erenshor
#
# macOS (CrossOver - find your bottle path in CrossOver settings):
#   ERENSHOR_GAME_PATH=/Users/username/Library/Application Support/CrossOver/Bottles/Erenshor/drive_c/Program Files (x86)/Steam/steamapps/common/Erenshor
#
# Linux (Steam):
#   ERENSHOR_GAME_PATH=~/.steam/steam/steamapps/common/Erenshor
#
# ERENSHOR_GAME_PATH=

# CrossOver bottle name (macOS only, for 'mod launch' command)
# Must match the folder name under ~/Library/Application Support/CrossOver/Bottles/
# e.g. if your ERENSHOR_GAME_PATH contains .../Bottles/Steam/... use Steam
# CROSSOVER_BOTTLE=Steam

# ==============================================================================
# How to Get Bot Credentials
# ==============================================================================
#
# 1. Log in to your wiki account
# 2. Go to Special:BotPasswords (e.g., https://erenshor.wiki.gg/wiki/Special:BotPasswords)
# 3. Create a new bot password with these grants:
#    - "Edit existing pages"
#    - "Create, edit, and move pages"
# 4. Copy the generated username and password to this file
# 5. The username format is: YourUsername@BotName
# 6. Keep this file secure and never commit it to version control!
#
# ==============================================================================
# How to Get Google Sheets Credentials
# ==============================================================================
#
# 1. Go to Google Cloud Console (https://console.cloud.google.com)
# 2. Create a new project or select existing
# 3. Enable Google Sheets API for the project
# 4. Create a service account with "Editor" role
# 5. Download the service account JSON key
# 6. Save to $HOME/.config/erenshor/google-credentials.json
# 7. Share your spreadsheets with the service account email
#
# ==============================================================================
